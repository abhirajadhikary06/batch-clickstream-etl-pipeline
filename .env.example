# CrateDB (dbt + warehouse)
CRATEDB_HOST=https://crate-db-warehouse.eks1.us-west-2.aws.cratedb.net:4200
CRATEDB_USERNAME=admin
CRATEDB_PASSWORD=
DBT_SCHEMA=analytics

# Supabase cloud target (gold analytics only)
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
SUPABASE_GOLD_SCHEMA=analytics_gold
SUPABASE_GOLD_TABLE=gold_url_daily_metrics

# Metabase integration (mandatory for BI)
METABASE_ENABLED=true
METABASE_URL=http://localhost:3002
METABASE_API_KEY=
METABASE_USERNAME=
METABASE_PASSWORD=
METABASE_CARD_IDS=
METABASE_SITE_URL=http://localhost:3002

# OpenObserve ingest hook (optional)
# Local example: http://localhost:5080/api/default/pipeline_events/_json
OPENOBSERVE_INGEST_URL=
# Base URL used by OTLP traces/metrics from orchestration (Dagster).
OPENOBSERVE_BASE_URL=http://localhost:5080
# Preferred auth for self-hosted OpenObserve.
OPENOBSERVE_USERNAME=admin@example.com
OPENOBSERVE_PASSWORD=
# Optional explicit OTLP endpoints. Leave empty to auto-derive from BASE_URL + org.
OPENOBSERVE_OTLP_TRACES_URL=
OPENOBSERVE_OTLP_METRICS_URL=
# Optional stream and org overrides.
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=pipeline_events
# Optional bearer token fallback (used when username/password are not set).
OPENOBSERVE_TOKEN=
OPENOBSERVE_TIMEOUT_SECONDS=10

# OpenObserve container bootstrap credentials for docker compose
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=Complexpass#123
